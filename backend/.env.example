# ──────────────────────────────────────────────
#  TimeTrack Pro — Backend Environment Variables
#  Скопируйте в .env и заполните своими значениями
# ──────────────────────────────────────────────

# Сервер
PORT=3000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=timetrack_pro
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT
# Генерация: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your_access_secret_64_chars_min
JWT_REFRESH_SECRET=your_refresh_secret_64_chars_min
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Логирование
LOG_LEVEL=info

# Rate limiting (настройки по умолчанию)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5
